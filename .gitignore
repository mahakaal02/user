# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Node (optional React frontend)
node_modules/
dist/
frontend/node_modules/
frontend/dist/

# Local tooling / machine-specific
.claude/
*.log

# Simulation run logs (regenerated) — but keep the canonical sample for --replay
runs/*.jsonl
!runs/demo.jsonl
# crowd-simulation instrumentation output (regenerated)
runs/sim_logs/

# Admin-saved model endpoints (may contain the private Qwen API key) — incl. backups
runs/model_endpoints.json*

# Public-fleet bot accounts (holds registered bot passwords — never commit)
runs/kalki_accounts.json

# Env / secrets (never commit)
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
