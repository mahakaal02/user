# Example environment for the bots simulator / live fleet.
# Copy to `.env` and fill in. `.env` is gitignored — NEVER commit real secrets.
# Load it into your shell before running, e.g.:  set -a; source .env; set +a

# --- Inference: real hosted Qwen over the OpenAI chat protocol (e.g. PodStack) ---
# Used when an inference backend is `qwen_openai` (config.yaml), or when these are
# set alongside a chat URL in the admin "Model endpoints" panel / config.live.yaml.
QWEN_OPENAI_URL=https://cloud.podstack.ai/api/v1/podvirt/chat/completions
QWEN_API_KEY=psk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen25-05b-instruct

# --- Inference: legacy custom servers (the "friend's machine") -------------------
# FINBERT_URL=http://192.168.1.50:8001/finbert
# QWEN_URL=http://192.168.1.50:8002/qwen        # custom {"task": ...} contract
# EMBED_URL=http://192.168.1.50:8003/embed      # news relevance embeddings

